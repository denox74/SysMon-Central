# ============================================================
#  SysMon Agent — Configuración
#  Copia este archivo a /etc/sysmon/agent.env y edítalo.
# ============================================================

# ----------------------------------------------------------
# OBLIGATORIO — sin esto el agente no arranca
# ----------------------------------------------------------

# URL base de tu backend Laravel (sin /api al final)
API_URL=https://tu-panel.ejemplo.com

# Token único de este agente (generado desde el panel)
AGENT_TOKEN=TU_TOKEN_AQUI

# ----------------------------------------------------------
# IDENTIFICACIÓN
# ----------------------------------------------------------

# Nombre descriptivo del agente (aparece en el panel)
# Si no se define, se usa el hostname del sistema
AGENT_NAME=mi-servidor-web

# ----------------------------------------------------------
# RECOLECCIÓN
# ----------------------------------------------------------

# Cada cuántos segundos enviar métricas (mínimo recomendado: 15)
INTERVAL_SECONDS=30

# Incluir lista de procesos activos en cada envío
SEND_PROCESSES=true

# Cuántos procesos incluir (top N por CPU)
PROCESSES_LIMIT=10

# ----------------------------------------------------------
# UMBRALES DE ALERTA LOCAL
# El agente evaluará estos umbrales y marcará alertas
# antes de enviar el payload al backend.
# El backend también puede tener sus propias reglas.
# ----------------------------------------------------------

# CPU
CPU_WARN_THRESHOLD=75
CPU_CRITICAL_THRESHOLD=90

# RAM
RAM_WARN_THRESHOLD=80
RAM_CRITICAL_THRESHOLD=95

# Temperaturas (°C)
TEMP_WARN_THRESHOLD=80
TEMP_CRITICAL_THRESHOLD=90

# Disco (%)
DISK_WARN_THRESHOLD=85

# ----------------------------------------------------------
# RED / REINTENTOS
# ----------------------------------------------------------

# Tiempo máximo de espera por request (segundos)
REQUEST_TIMEOUT=10

# Máximo de payloads en cola si el servidor no responde
MAX_QUEUE=50

# ----------------------------------------------------------
# LOGGING
# ----------------------------------------------------------

# Nivel: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Archivo de log (opcional, si no se define sólo va a stdout)
# LOG_FILE=/var/log/sysmon/agent.log
